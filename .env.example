PORT=3000
API_TOKEN=change-me-generate-with-openssl-rand-hex-32
WG_INTERFACE=awg0
WG_CONFIG_PATH=/etc/amnezia/amneziawg/awg0.conf
SERVER_PUBLIC_IP=
SERVER_PORT=443
DNS_SERVER=10.0.0.1
AWG_LOCAL_PORT=51820
# Optional — defaults to 10.0.0.0/24 if unset. Set to a distinct 10.0.N.0/24 per
# node so migrating a device between nodes never collides on allowed_ip.
PEER_IP_RANGE=
AWG_JC=
AWG_JMIN=
AWG_JMAX=
AWG_S1=
AWG_S2=
AWG_H1=
AWG_H2=
AWG_H3=
AWG_H4=
AWG_PEER_RATE_MBIT=20
AWG_PEER_CONNLIMIT=200

# VLESS + Reality (Этап 1 VLESS_Reality.md) — optional, wg-manager falls back to
# 503 VLESS_NOT_AVAILABLE on nodes without Xray installed (see server-nl/xray/README.md)
XRAY_CONFIG_PATH=/usr/local/etc/xray/config.json
XRAY_BIN=/usr/local/bin/xray
XRAY_API_ADDR=127.0.0.1:10085
# Public Reality params (safe to expose to clients) — private key stays in config.json only
XRAY_REALITY_PUBLIC_KEY=
XRAY_REALITY_SNI=www.samsung.com
XRAY_REALITY_SHORT_ID=
XRAY_REALITY_PORT=443
